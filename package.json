{
  "name": "x3d-traverse",
  "version": "2.0.1",
  "description": "Traverse X3D Nodes and Scenes to Filter, Process and Analyze Nodes",
  "main": "dist/traverse.js",
  "module": "dist/traverse.mjs",
  "exports": {
    ".": {
      "require": "./dist/traverse.js",
      "import": "./dist/traverse.mjs",
      "types": "./dist/traverse.d.ts"
    }
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "dist": "node build/dist.js",
    "prerelease": "npm run dist",
    "release": "node build/release.js",
    "pretest": "npm run dist",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/create3000/x3d-traverse.git"
  },
  "keywords": [
    "3D",
    "Browser",
    "JavaScript",
    "Node",
    "VRML",
    "x_ite",
    "X3D",
    "XML"
  ],
  "author": "Holger Seelig <holger.seelig@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/create3000/x3d-traverse/issues"
  },
  "homepage": "https://github.com/create3000/x3d-traverse#readme",
  "funding": {
    "type": "patreon",
    "url": "https://patreon.com/X_ITE"
  },
  "devDependencies": {
    "@create3000/jest-electron-runner": "^29.15.2",
    "shell-tools": "^1.1.9",
    "terser-webpack-plugin": "^5.6.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.2",
    "x_ite": "^15.0.3",
    "x_ite-node": "^2.0.18"
  },
  "jest": {
    "runner": "@create3000/jest-electron-runner",
    "testEnvironment": "@create3000/jest-electron-runner/environment"
  }
}
